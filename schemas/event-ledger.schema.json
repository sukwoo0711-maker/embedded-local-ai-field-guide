{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/embedded-local-ai-field-guide/event-ledger.schema.json",
  "title": "Project memory ledger event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "event_id", "timestamp_utc", "event_type", "status",
    "sensitivity", "summary", "source_commit", "model_generated", "references", "evidence"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "event_id": {"type": "string", "pattern": "^EV-[0-9]{8}-[0-9]{4}$"},
    "timestamp_utc": {"type": "string", "format": "date-time"},
    "event_type": {"enum": ["observation", "issue", "attempt", "result", "decision", "note"]},
    "status": {"enum": ["proposed", "verified", "rejected", "superseded"]},
    "sensitivity": {"enum": ["public", "internal", "restricted"]},
    "summary": {"type": "string", "minLength": 1},
    "source_commit": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      ]
    },
    "model_generated": {"type": "boolean"},
    "references": {
      "type": "array",
      "items": {"type": "string", "pattern": "^EV-[0-9]{8}-[0-9]{4}$"},
      "uniqueItems": true
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "sha256", "locator"],
        "properties": {
          "artifact_id": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "locator": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
